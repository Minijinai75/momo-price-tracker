# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 監控設定
# 檢查間隔（cron 格式）
# 預設每天台灣時間 00:30 檢查一次（UTC 16:30）
# 格式: 分 時 日 月 星期
# 範例: 30 16 * * * = 每天台灣時間 00:30
CHECK_INTERVAL=30 16 * * *

# 要監控的商品列表（用逗號分隔多個商品代碼）
# 可透過 Telegram Bot 命令 /add 動態新增，不一定要在這裡設定
PRODUCT_CODES=11593255

# 資料庫檔案路徑（用於儲存價格歷史）
DATA_FILE=./data/prices.json

# 是否在啟動時立即檢查
CHECK_ON_START=true

# 伺服器設定（Zeabur 部署時使用）
PORT=3000
# Webhook URL（Zeabur 會自動設定，本地開發留空）
WEBHOOK_URL=
